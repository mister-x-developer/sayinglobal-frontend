# ============================================================
# SAYIN GLOBAL — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# WebSocket URL (no trailing slash)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Telegram bot username (without @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=sayinglobal_bot

# App URL (used for OG tags and share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# reCAPTCHA (optional)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Environment
NEXT_PUBLIC_ENV=development

# ============================================================
# PRODUCTION VALUES (set in Vercel dashboard or .env.local)
# ============================================================
# NEXT_PUBLIC_API_URL=https://sayinglobal.up.railway.app/api
# NEXT_PUBLIC_WS_URL=wss://sayinglobal.up.railway.app/ws
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=sayin_global_bot
# NEXT_PUBLIC_APP_URL=https://sayinglobal.vercel.app
# NEXT_PUBLIC_SITE_URL=https://sayinglobal.vercel.app
# NEXT_PUBLIC_ENV=production
