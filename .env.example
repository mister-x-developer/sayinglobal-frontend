# ──────────────────────────────────────────────────────────────────────────────
# Web Frontend environment template (Next.js 14 App Router)
# Copy to `frontend/.env.local` and fill in real values.
#
# Live values for production are configured in the Vercel dashboard:
#   Project → Settings → Environment Variables
#
# Variables prefixed with `NEXT_PUBLIC_` are exposed to the browser bundle.
# Anything that must stay server-only (build-time tokens, secrets) MUST NOT
# carry that prefix. Never commit real secrets to this template.
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend integration ───────────────────────────────────────────────────────
# Required — Backend REST API base URL (no trailing slash).
# Local dev:   http://localhost:8000/api
# Production:  https://sayinglobal.up.railway.app/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Required — Backend WebSocket base URL (no trailing slash).
# Local dev:   ws://localhost:8000/ws
# Production:  wss://sayinglobal.up.railway.app/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Optional — Force direct API calls instead of the same-origin proxy.
# Set to 'true' to bypass the localhost/Vercel same-origin proxy and call
# NEXT_PUBLIC_API_URL directly (useful for debugging). Defaults to proxy mode.
NEXT_PUBLIC_DIRECT_API=

# ── Public site URLs ──────────────────────────────────────────────────────────
# Required — Canonical public URL of this Web Frontend. Used for absolute
# links, OG/Twitter share metadata, and email/Telegram callbacks.
# Local dev:   http://localhost:3000
# Production:  https://sayinglobal.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — Legacy alias of NEXT_PUBLIC_APP_URL kept for older code paths.
# Set to the same value as NEXT_PUBLIC_APP_URL. New code SHOULD prefer
# NEXT_PUBLIC_APP_URL; this key may be removed in a future release.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Telegram integration ──────────────────────────────────────────────────────
# Required — Telegram bot username (without leading '@'). Used by the
# "Continue with Telegram" CTA and the bot deep-link generator.
# Production: sayin_global_bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=sayin_global_bot

# ── Analytics & anti-abuse (optional) ─────────────────────────────────────────
# Optional — Google Analytics 4 measurement ID (G-XXXXXXXXXX). Leave blank
# to disable GA in non-production environments.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional — Google reCAPTCHA v3 site key. Leave blank to disable reCAPTCHA
# challenges (the backend gates this with its own server-side secret key).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ── Environment metadata ──────────────────────────────────────────────────────
# Optional — Logical environment name. One of: development | staging | production.
# Defaults to 'development' when unset.
NEXT_PUBLIC_ENV=development

# Optional — Application version label, exposed in the footer and attached to
# Sentry events. Should match the package.json version or the release tag.
NEXT_PUBLIC_APP_VERSION=1.0.0

# Optional — Release identifier used by `@sentry/nextjs` for source-map
# association. Typically set automatically by the CI to the git SHA, but can
# be overridden here for local debugging.
NEXT_PUBLIC_RELEASE=

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# Optional — Public Sentry DSN for client-side error reporting. Leave blank
# to disable Sentry on the browser. Set to the project's DSN in production.
NEXT_PUBLIC_SENTRY_DSN=

# Optional — Sentry environment tag attached to events. Should mirror
# NEXT_PUBLIC_ENV in most cases ('development' | 'stagingʻ | 'production').
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Required for production builds — Build-time Sentry auth token used by
# `@sentry/nextjs` to upload source maps during `next build`. WITHOUT this
# token the build still succeeds, but stack traces remain obfuscated.
#
# This variable is BUILD-TIME ONLY and MUST NOT carry the `NEXT_PUBLIC_`
# prefix — it is never exposed to the browser bundle. Configure it in the
# Vercel dashboard (Project → Settings → Environment Variables → Production)
# and DO NOT commit a real token here.
SENTRY_AUTH_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# PRODUCTION REFERENCE VALUES (managed in the Vercel dashboard)
# ──────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://sayinglobal.up.railway.app/api
# NEXT_PUBLIC_WS_URL=wss://sayinglobal.up.railway.app/ws
# NEXT_PUBLIC_APP_URL=https://sayinglobal.vercel.app
# NEXT_PUBLIC_SITE_URL=https://sayinglobal.vercel.app
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=sayin_global_bot
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-PE3QVRBQFL
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=<set-in-vercel>
# NEXT_PUBLIC_ENV=production
# NEXT_PUBLIC_SENTRY_DSN=<set-in-vercel>
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_APP_VERSION=1.0.0
# SENTRY_AUTH_TOKEN=<set-in-vercel>
